{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DayRecord",
  "version": "0.1.1",
  "identifier": "com.dayrecord.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../../frontend run build",
    "beforeBuildCommand": "npm --prefix ../../frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DayRecord",
        "width": 460,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
