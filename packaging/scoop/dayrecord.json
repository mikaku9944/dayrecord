# DayRecord CLI — Scoop manifest (example)
# Usage: scoop bucket add dayrecord <this-repo-url> && scoop install dayrecord

{
    "version": "0.1.1",
    "description": "DayRecord CLI and MCP server for AI agents",
    "homepage": "https://github.com/mikaku9944/dayrecord",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/mikaku9944/dayrecord/releases/download/v0.1.1/dayrecord-0.1.1-x86_64-pc-windows-msvc.zip",
            "hash": "REPLACE_AT_RELEASE"
        }
    },
    "bin": [
        "dayrecord.exe",
        ["dayrecord.exe", "dayrecord-mcp", "mcp"]
    ],
    "checkver": {
        "github": "https://github.com/mikaku9944/dayrecord"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mikaku9944/dayrecord/releases/download/v$version/dayrecord-$version-x86_64-pc-windows-msvc.zip"
            }
        }
    }
}
